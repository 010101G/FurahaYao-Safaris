# ── Email (contact form) ──────────────────────────────
# The /api/contact route uses nodemailer with these values.
# Copy this file to ".env.local" and fill in real credentials,
# then restart the dev server (npm run dev).

# SMTP server (examples below)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false            # "true" only for port 465

# SMTP login
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-app-password  # Gmail: create an App Password (not your normal password)

# Addresses
SMTP_FROM=your-account@gmail.com   # the "from" address
COMPANY_EMAIL=info@furahayaosafaris.com   # where new enquiries are delivered

# ── Provider notes ────────────────────────────────────
# Gmail:    host smtp.gmail.com, port 587, secure false, App Password required
# Brevo:    host smtp-relay.brevo.com, port 587
# SendGrid: host smtp.sendgrid.net, port 587, user "apikey", pass <API key>
# Mailgun:  host smtp.mailgun.org, port 587
